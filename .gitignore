# AethelLib Industrial Whitelist
# Ignore everything by default
*

# Allow the Industrial Payload
!scripts/
!scripts/**
!entities/
!entities/**
!manifest.json
!Docs/
!Docs/**
!pack_icon.png
!README.md
!LICENSE
!.gitignore
!tools/
!tools/**

# Exclude private LLM and history purging tools from tracking
tools/*ship*
tools/msg_filter.ps1
tools/purge_history.ps1


# LLM EXCLUSION ZONE (Strict Lockdown)
*LLM*
*DUMP*
*dump*
AethelLib*.txt
AethelLib(*).txt
ship_payload.ps1
scripts/ship_payload.ps1
scripts/*.ps1

# Prevent accidental inclusion of system files
.DS_Store
Thumbs.db
node_modules/
BDS/
worlds/
*.db
*.log
ContentLog*
